{
  "name": "homestead",
  "version": "0.0.0",
  "private": true,
  "description": "Homestead monorepo. The frontend lives in ./frontend (the host app) and publishable packages live in ./packages/*.",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --filter frontend dev",
    "build": "pnpm -r --if-present build",
    "lint": "pnpm -r --if-present lint",
    "type-check": "pnpm -r --if-present type-check",
    "test": "pnpm -r --if-present test"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "unrs-resolver",
      "esbuild"
    ]
  }
}
